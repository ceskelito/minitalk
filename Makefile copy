NAME	:= client server

CC 		:= cc
CFLAGS 	:= -Wall -Wextra -Werror
RM 		:= rm -f

LIB 	:= libft/libft.a

M_DIR 			:= mandatory
M_CLIENT_SRC 	:= client.c
M_SERVER_SRC 	:= server.c

B_DIR			:= bonus_dir
B_CLIENT_SRC 	:= bonus_client.c
B_SERVER_SRC 	:= bonus_server.c

CLIENT_SRC 	= $(M_CLIENT_SRC)
SERVER_SRC 	= $(M_SERVER_SRC)
DIR			= $(M_DIR)

CLIENT_OBJ = $(DIR)/$(CLIENT_SRC:.c=.o)
SERVER_OBJ = $(DIR)/$(SERVER_SRC:.c=.o)

%.o: %.c
	$(CC) $(CFLAGS) -c $< -o $@
 
all: $(NAME)

client: $(CLIENT_OBJ) $(LIB)
	$(CC) $(CFLAGS) $(CLIENT_OBJ) $(LIB) -o client

server: $(SERVER_OBJ) $(LIB)
	$(CC) $(CFLAGS) $(SERVER_OBJ) $(LIB) -o server

bonus: set_bonus all

set_bonus:
	DIR = $(B_DIR)
	CLIENT_SRC = $(B_CLIENT_SRC)
	SERVER_SRC = $(B_SERVER_SRC)
	
$(LIB):
	@make -C libft

clean:
	@make -C libft clean
	rm -f $(CLIENT_OBJ) $(SERVER_OBJ)

fclean: clean
	@make -C libft fclean
	$(RM) client server

re: fclean all

.PHONY: re all clean fclean set_bonus